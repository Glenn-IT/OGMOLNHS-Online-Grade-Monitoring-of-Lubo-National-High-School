# OGMS – Root .htaccess
Options -Indexes

# Deny direct access to sensitive directories (config, database, data)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to config directory
    RewriteRule ^config/             - [F,L]

    # Block access to database directory
    RewriteRule ^database/           - [F,L]

    # Block access to raw data files
    RewriteRule ^data/               - [F,L]

    # Block access to dot files (.env, .git, etc.)
    RewriteRule (^|/)\.              - [F,L]
</IfModule>

# Block direct access to PHP config and seed files
<FilesMatch "^(seed\.php)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Security headers for all HTML/PHP responses
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# PHP error display — off in production, errors go to log only
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>
